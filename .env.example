# Copy to .env and adjust. All variables are optional; defaults are shown.
# Loaded automatically by app/config.py (pydantic-settings).

# Queue / worker pool
JOB_MAX_WORKERS=4
JOB_QUEUE_SIZE=1000

# External call
JOB_REQUEST_TIMEOUT_SECONDS=30.0

# Simulated processing time before the external call (0 to disable)
JOB_SIMULATED_WORK_SECONDS=2.0

# Retry policy (transient failures only)
JOB_MAX_RETRIES=3
JOB_RETRY_BASE_DELAY=0.5
JOB_RETRY_MAX_DELAY=10.0
JOB_RETRY_BACKOFF_FACTOR=2.0
